SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
API_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
# Only use this for local testing.
TESTING_MODE=false

# Put the Paystack test secret in .env.local, not here.
PAYSTACK_SECRET_KEY=sk_test_your-secret-key
# Public backend URL for callbacks and webhooks.
APP_PUBLIC_URL=https://api.your-domain.com
